{
    "name": "aymericcucherousset/ux-sortable",
    "description": "Sortable integration for Symfony",
    "type": "symfony-bundle",
    "keywords": [
        "symfony-ux",
        "sortable"
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Aymericcucherousset\\Ux\\Sortable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aymericcucherousset\\Ux\\Sortable\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "vendor/bin/php-cs-fixer fix && vendor/bin/phpstan analyse"
    },
    "authors": [
        {
            "name": "aymericcucherousset",
            "email": "aymeric.cucherousset@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": ">=8.3",
        "symfony/config": "^7.0|^8.0",
        "symfony/dependency-injection": "^7.0|^8.0",
        "symfony/stimulus-bundle": "^2.22",
        "twig/twig": "^3.8"
    },
    "extra": {
        "thanks": {
        "name": "symfony/ux",
        "url": "https://github.com/symfony/ux"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "2.2.x-dev",
        "friendsofphp/php-cs-fixer": "dev-master"
    }
}
